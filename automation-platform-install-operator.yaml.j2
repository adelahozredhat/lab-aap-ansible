{% for i in range(1, num_users|int + 1) %}
---
apiVersion: v1
kind: Namespace
metadata:
  labels:
    openshift.io/cluster-monitoring: "true"
  name: ansible-automation-platform{{ i }}
---
apiVersion: operators.coreos.com/v1
kind: OperatorGroup
metadata:
  name: ansible-automation-platform-operator{{ i }}
  namespace: ansible-automation-platform{{ i }}
spec:
  targetNamespaces:
    - ansible-automation-platform{{ i }}
---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: ansible-automation-platform{{ i }}
  namespace: ansible-automation-platform{{ i }}
spec:
  channel: 'stable-2.6'
  installPlanApproval: Automatic
  name: ansible-automation-platform-operator
  source: redhat-operators
  sourceNamespace: openshift-marketplace
{% endfor %}