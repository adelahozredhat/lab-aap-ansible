{% for i in range(1, num_users|int + 1) %}

---
apiVersion: v1
data:
  password: YWRtaW4=
kind: Secret
metadata:
  labels:
    app.kubernetes.io/component: aap
    app.kubernetes.io/name: example
    app.kubernetes.io/operator-version: ""
    app.kubernetes.io/part-of: example
  name: example-admin-password{{ i }}
  namespace: ansible-automation-platform{{ i }}
---

apiVersion: aap.ansible.com/v1alpha1
kind: AnsibleAutomationPlatform
metadata:
  name: example{{ i }}
  namespace: ansible-automation-platform{{ i }}
spec:
  admin_password_secret: example-admin-password{{ i }}
  route_tls_termination_mechanism: Edge
  # no_log: true
  redis_mode: standalone
  api:
    log_level: INFO
    replicas: 1
  extra_settings:
    - setting: REDIRECT_IS_HTTPS
      value: '"True"'
  database:
    postgres_data_volume_init: false
    resource_requirements:
      requests:
        cpu: 200m
        memory: 512Mi
    storage_requirements:
      requests:
        storage: 10Gi
  # Platform
  image_pull_policy: IfNotPresent
  # Components
  controller:
    disabled: false
  eda:
    worker:
      replicas: 1
    scheduler:
      replicas: 1
    disabled: false
  hub:
    worker:
      replicas: 1
    web:
      replicas: 1
    content:
      replicas: 1
    disabled: true
    ## Modify to contain your RWM storage class name
    storage_type: file
    file_storage_storage_class: crc-csi-hostpath-provisioner
    file_storage_size: 10Gi

    ## uncomment if using S3 storage for Content pod
    # storage_type: S3
    # object_storage_s3_secret: example-galaxy-object-storage

    ## uncomment if using Azure storage for Content pod
    # storage_type: azure
    # object_storage_azure_secret: azure-secret-name
  lightspeed:
    disabled: true
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: eda-webhook-external{{ i }}
  namespace: ansible-automation-platform{{ i }}
  labels:
    app: ansible-eda
spec:
  # El host se puede omitir y OpenShift generará uno automáticamente
  # O puedes definir uno específico: host: eda-webhook.apps.mi-cluster.com
  to:
    kind: Service
    name: example-rulebook-activation  # El nombre del Service que apunta al puerto 5000
    weight: 100
  port:
    targetPort: 5000
  tls:
    termination: edge          # Esto habilita HTTPS en el router de OpenShift
    insecureEdgeTerminationPolicy: Allow # Opcional: permite redirección de HTTP a HTTPS
{% endfor %}